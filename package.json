{
  "name": "sportapp",
  "version": "1.0.0",
  "private": true,
  "description": "Sport Tracker mobile wrapper setup with Capacitor",
  "scripts": {
    "prepare:web": "node scripts/sync-web.js",
    "cap:sync": "npm run prepare:web && npx cap sync",
    "cap:copy": "npm run prepare:web && npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2"
  }
}
